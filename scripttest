TextBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
TextBox.Text = "r6"
TextBox.TextColor3 = Color3.new(1,1,1)
TextBox.TextSize = 16
TextBox.Font = Enum.Font.Gotham
TextBox.PlaceholderText = "e.g. r6, reset, sit"
TextBox.Parent = Content

local TextCorner = Instance.new("UICorner")
TextCorner.CornerRadius = UDim.new(0, 6)
TextCorner.Parent = TextBox

-- Variables
local Enabled = false
local CommandText = "r6"

-- Checkbox Toggle
CheckBox.MouseButton1Click:Connect(function()
    Enabled = not Enabled
    CheckBox.BackgroundColor3 = Enabled and Color3.fromRGB(0, 170, 100) or Color3.fromRGB(50, 50, 50)
end)

-- Update command text
TextBox:GetPropertyChangedSignal("Text"):Connect(function()
    CommandText = TextBox.Text
end)

-- Function to send the message
local function AutoSay(player)
    if not Enabled or not player or player == LocalPlayer then return end
    if not CommandText or CommandText == "" then return end

    local message = ";" .. CommandText .. " " .. player.Name
    
    -- Fire chat message
    local success, err = pcall(function()
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(message, "All")
    end)
    
    if success then
        print("Auto Said: " .. message)
    else
        warn("Failed to send message: " .. tostring(err))
    end
end

-- When a NEW player joins
Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function()
        wait(1.5) -- Small delay to let character load properly
        AutoSay(player)
    end)
end)

-- For players already in the server (including yourself - but we skip self)
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer and player.Character then
        player.CharacterAdded:Connect(function()
            wait(1.5)
            AutoSay(player)
        end)
    end
end)

-- Close Button
CloseBtn.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
    print("UI Closed")
end)

print("🎉 UI Ready!")
print("Auto Say is now active on both Player Join and Respawn.")
