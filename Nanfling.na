-- ── LÓGICA DE ACTUALIZACIÓN VISUAL (HEARTBEAT) ──
Runservice.Heartbeat:Connect(function()
	local query = textbox.Text:lower():gsub("%s+","")
	local trgt = nil
	if query ~= "" then
		for _,p in ipairs(Players:GetPlayers()) do
			if p ~= Players.LocalPlayer and (p.Name:lower():find(query,1,true) or p.DisplayName:lower():gsub("%s+",""):find(query,1,true)) then
				trgt = p; break
			end
		end
	end
	local lpChar = Players.LocalPlayer.Character
	if trgt and trgt.Character and lpChar and lpChar:FindFirstChild("HumanoidRootPart") and trgt.Character:FindFirstChild("HumanoidRootPart") then
		local dist = (lpChar.HumanoidRootPart.Position - trgt.Character.HumanoidRootPart.Position).Magnitude
		studsLbl.Text = string.format("Distancia al objetivo: %.1f Studs", dist)
	else studsLbl.Text = "Distancia: N/A" end
	if trgt and trgt.Character then
		espHighlight.Adornee = trgt.Character
		espHighlight.OutlineColor = Color3.fromHSV(tick() % 3 / 3, 1, 1)
	else espHighlight.Adornee = nil end
end)

local panelVisible = true
toggleBtn.MouseButton1Click:Connect(function()
	animateToggleClick()
	panelVisible = not panelVisible
	if panelVisible then
		panel.Visible = true
		TweenService:Create(panel, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size=UDim2.new(0,W,0,H)}):Play()
		toggleBtn.Text = "🥊"
	else
		TweenService:Create(panel, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size=UDim2.new(0,W,0,0)}):Play()
		task.delay(0.2, function() panel.Visible = false end)
		toggleBtn.Text = "👁"
	end
end)

local function findPlayer(query)
	if not query or query == "" then return nil end
	query = query:lower():gsub("%s+","")
	local speaker = Players.LocalPlayer
	local all = Players:GetPlayers()
	for _,p in ipairs(all) do if p~=speaker and p.Name:lower()==query then return p end end
	for _,p in ipairs(all) do if p~=speaker and p.DisplayName:lower():gsub("%s+","")==query then return p end end
	for _,p in ipairs(all) do if p~=speaker and p.Name:lower():find(query,1,true) then return p end end
	for _,p in ipairs(all) do if p~=speaker and p.DisplayName:lower():gsub("%s+",""):find(query,1,true) then return p end end
	return nil
end

local function getHeight()
	local v = tonumber(heightTB.Text)
	return (v and v == v) and v or 0
end

local loopActive  = false
local loopConn    = nil
local viewActive  = false
local viewConn    = nil
local savedCFrame = nil

local function restorePosition()
	local char = Players.LocalPlayer.Character
	if char and savedCFrame then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hrp then hrp.CFrame = savedCFrame end
		if hum then hum.PlatformStand = false end
	end
	savedCFrame = nil
end

local function startView()
	if viewConn then viewConn:Disconnect() end
	local cam = workspace.CurrentCamera
	viewConn = Runservice.Heartbeat:Connect(function()
		local trgt = findPlayer(textbox.Text); if not trgt then return end
		local chr  = trgt.Character;          if not chr  then return end
		local hum  = chr:FindFirstChildOfClass("Humanoid"); if not hum then return end
		cam.CameraType = Enum.CameraType.Custom; cam.CameraSubject = hum
	end)
end

local function stopView()
	if viewConn then viewConn:Disconnect(); viewConn = nil end
	workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
	local char = Players.LocalPlayer.Character
	if char then
		workspace.CurrentCamera.CameraSubject = char:FindFirstChildOfClass("Humanoid") or char:FindFirstChild("HumanoidRootPart")
	end
end

-- Función nativa para ejecutar el Fling desde la GUI
local function runFlingAttack(trgt, customDuration)
	local speaker = Players.LocalPlayer
	local char = speaker.Character
	local trgt_chr = trgt.Character
	if not (char and trgt_chr) then return end

	local hrp = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	local trgt_hrp = trgt_chr:FindFirstChild("HumanoidRootPart")
	if not (hrp and hum and trgt_hrp) then return end

	local nan_vector = Vector3.new(0/0, 0/0, 0/0)
	local original_cframe = hrp.CFrame
	hum.PlatformStand = true
	
	local start_time = tick()
	local duration = customDuration or 1.5
	local attackConn
	
	attackConn = Runservice.Heartbeat:Connect(function()
		local current_time = tick()
		if (current_time - start_time) >= duration or not char.Parent or not trgt_chr.Parent or not hrp.Parent or not trgt_hrp.Parent then
			attackConn:Disconnect()
			if hrp then
				hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
				hrp.CFrame = original_cframe
			end
			if hum then hum.PlatformStand = false end
			return
		end
		
		local yOff = getHeight()
		hrp.CFrame = trgt_hrp.CFrame * CFrame.new(0, yOff, 0)
		hrp.AssemblyLinearVelocity = nan_vector
		hrp.AssemblyAngularVelocity = nan_vector
		pcall(function() hum:Move(nan_vector) end)
		if sethiddenproperty then pcall(function() sethiddenproperty(hrp, "PhysicsRepRootPart", trgt_hrp) end) end
	end)
end

local function startLoop()
	if loopConn then loopConn:Disconnect(); loopConn = nil end
	local speaker = Players.LocalPlayer
	local nan_vector = Vector3.new(0/0, 0/0, 0/0)

	loopConn = Runservice.Heartbeat:Connect(function()
		local name = textbox.Text
		if name == "" then return end

		local trgt = findPlayer(name)
		if not trgt then setStatus("Jugador no encontrado", Color3.fromRGB(255,80,80)); return end

		local char     = speaker.Character
		local trgt_chr = trgt.Character
		if not (char and trgt_chr) then return end

		local hrp      = char:FindFirstChild("HumanoidRootPart")
		local hum      = char:FindFirstChildOfClass("Humanoid")
		local trgt_hrp = trgt_chr:FindFirstChild("HumanoidRootPart")
		if not (hrp and hum and trgt_hrp) then return end

		if not savedCFrame then savedCFrame = hrp.CFrame end
		local yOff = getHeight()
		
		hum.PlatformStand = true
		hrp.CFrame = trgt_hrp.CFrame * CFrame.new(0, yOff, 0)
		hrp.AssemblyLinearVelocity = nan_vector
		hrp.AssemblyAngularVelocity = nan_vector
		pcall(function() hum:Move(nan_vector) end)
		if sethiddenproperty then pcall(function() sethiddenproperty(hrp, "PhysicsRepRootPart", trgt_hrp) end) end
	end)
end

local function stopLoop()
	if loopConn then loopConn:Disconnect(); loopConn = nil end
	restorePosition()
end

loopBtn.MouseButton1Click:Connect(function()
	loopActive = not loopActive
	if loopActive then
		if textbox.Text == "" then setStatus("Escribe un nombre primero", Color3.fromRGB(255,200,0)); loopActive = false; return end
		loopBtn.Text = "🔁 LOOP: ON"; loopBtn.TextColor3 = Color3.fromRGB(140,255,150)
		TweenService:Create(loopStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(60,220,100)}):Play()
		setStatus("Loop activo", Color3.fromRGB(80,255,130)); startLoop()
	else
		loopBtn.Text = "🔁 LOOP: OFF"; loopBtn.TextColor3 = Color3.fromRGB(255,255,255)
		TweenService:Create(loopStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(130,20,20)}):Play()
		setStatus("Loop off · regresaste", Color3.fromRGB(255,140,0)); stopLoop()
	end
end)

viewBtn.MouseButton1Click:Connect(function()
	viewActive = not viewActive
	if viewActive then
		if textbox.Text == "" then setStatus("Escribe un nombre primero", Color3.fromRGB(255,200,0)); viewActive = false; return end
		viewBtn.Text = "👁 VIEW: ON"; viewBtn.TextColor3 = Color3.fromRGB(120,210,255)
		TweenService:Create(viewStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(60,160,255)}):Play()
		local trgt = findPlayer(textbox.Text)
		setStatus("Viendo: "..(trgt and trgt.Name or textbox.Text), Color3.fromRGB(100,200,255))
		startView()
	else
		viewBtn.Text = "👁 VIEW: OFF"; viewBtn.TextColor3 = Color3.fromRGB(255,255,255)
		TweenService:Create(viewStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(30,80,160)}):Play()
		setStatus("Vista restaurada", Color3.fromRGB(255,180,180)); stopView()
	end
end)

panel.Size = UDim2.new(0,W,0,0)
TweenService:Create(panel, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0,W,0,H)}):Play()

-- ── ACOPLAMIENTO DE PLUGIN PARA EL ADMIN (CONSOLA/CHAT) ──
cmdPluginAdd = {
    Aliases = {"nanfling", "nfling", "nanf"},
    ArgsHint = "[player]",
    Info = "Abre la interfaz visual de NaN Fling y permite atacar via comando de consola.",
    Function = function(args)
        -- Si usaron el comando de chat con un argumento (ej: ;nanfling rob), ejecuta el ataque rápido sin abrir el panel
        if args[1] then
            local targetName = args[1]:lower()
            local foundTarget = nil
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= Players.LocalPlayer and (p.Name:lower():find(targetName, 1, true) or p.DisplayName:lower():find(targetName, 1, true)) then
                    foundTarget = p
                    break
                end
            end
            if foundTarget then
                runFlingAttack(foundTarget, 1.5)
            end
        else
            -- Si solo escribieron el comando plano (;nanfling), reabre/muestra la interfaz visual si estaba minimizada
            panel.Visible = true
            panel.Size = UDim2.new(0, W, 0, H)
            toggleBtn.Text = "🥊"
            panelVisible = true
        end
    end,
    RequiresArguments = false
}
