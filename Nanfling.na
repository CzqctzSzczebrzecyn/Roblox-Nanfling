local TOGGLE_POS  = UDim2.new(0, 12, 0, 60)
local TOGGLE_SIZE = UDim2.new(0, 44, 0, 44)

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size             = TOGGLE_SIZE
toggleBtn.Position         = TOGGLE_POS
toggleBtn.BackgroundColor3 = Color3.fromRGB(130, 12, 12)
toggleBtn.Text             = "🥊"
toggleBtn.TextSize         = 20
toggleBtn.Font             = Enum.Font.GothamBold
toggleBtn.TextColor3       = Color3.fromRGB(255, 255, 255)
toggleBtn.BorderSizePixel  = 0
toggleBtn.ZIndex           = 10
toggleBtn.Parent           = gui

local tc = Instance.new("UICorner"); tc.CornerRadius = UDim.new(0,10); tc.Parent = toggleBtn
local ts = Instance.new("UIStroke"); ts.Color = Color3.fromRGB(180,20,20); ts.Thickness = 2; ts.Parent = toggleBtn

TweenService:Create(ts, TweenInfo.new(1.0, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
	Color = Color3.fromRGB(255,255,255), Transparency = 0.1
}):Play()

local function animateToggleClick()
	TweenService:Create(toggleBtn, TweenInfo.new(0.09, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(0,52,0,52), Position = UDim2.new(0,8,0,56),
		BackgroundColor3 = Color3.fromRGB(255,255,255)
	}):Play()
	TweenService:Create(ts, TweenInfo.new(0.09), {Thickness = 4, Transparency = 0}):Play()
	task.delay(0.12, function()
		TweenService:Create(toggleBtn, TweenInfo.new(0.38, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {
			Size = TOGGLE_SIZE, Position = TOGGLE_POS,
			BackgroundColor3 = Color3.fromRGB(130,12,12)
		}):Play()
		TweenService:Create(ts, TweenInfo.new(0.25), {Thickness = 2}):Play()
	end)
end

