local viewStroke = Instance.new("UIStroke"); viewStroke.Color = Color3.fromRGB(30,80,160);  viewStroke.Thickness = 1.5; viewStroke.Parent = viewBtn

local function makeMiniTB(placeholder, posX, posY)
	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(0,BW,0,28); bg.Position = UDim2.new(0,posX,0,posY)
	bg.BackgroundColor3 = Color3.fromRGB(20,6,6); bg.BorderSizePixel = 0; bg.ZIndex = 6; bg.Parent = panel
	local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,7); c.Parent = bg
	local s = makeStroke(bg, Color3.fromRGB(90,14,14))
	local tb = Instance.new("TextBox")
	tb.PlaceholderText = placeholder; tb.PlaceholderColor3 = Color3.fromRGB(110,55,55); tb.Text = ""
	tb.Font = Enum.Font.Gotham; tb.TextSize = 11; tb.TextColor3 = Color3.fromRGB(255,200,200)
	tb.BackgroundTransparency = 1; tb.Size = UDim2.new(1,-14,1,0); tb.Position = UDim2.new(0,8,0,0)
	tb.TextXAlignment = Enum.TextXAlignment.Left; tb.ClearTextOnFocus = false
	tb.ZIndex = 7; tb.Parent = bg
	tb.Focused:Connect(function() TweenService:Create(s,TweenInfo.new(0.15),{Color=Color3.fromRGB(255,255,255)}):Play() end)
	tb.FocusLost:Connect(function() TweenService:Create(s,TweenInfo.new(0.15),{Color=Color3.fromRGB(90,14,14)}):Play() end)
	return tb
end

