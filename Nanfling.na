local function makeBtn(text, posX, posY, w, h, c1, c2)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0,w,0,h); btn.Position = UDim2.new(0,posX,0,posY)
	btn.BackgroundColor3 = c1; btn.Text = text; btn.TextSize = 11
	btn.Font = Enum.Font.GothamBold; btn.TextColor3 = Color3.fromRGB(255,255,255)
	btn.BorderSizePixel = 0; btn.AutoButtonColor = false; btn.ZIndex = 6; btn.Parent = panel
	local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,8); c.Parent = btn
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0,c1),ColorSequenceKeypoint.new(1,c2)})
	g.Rotation = 90; g.Parent = btn
	btn.MouseEnter:Connect(function() TweenService:Create(btn,TweenInfo.new(0.12),{BackgroundColor3=c2}):Play() end)
	btn.MouseLeave:Connect(function() TweenService:Create(btn,TweenInfo.new(0.12),{BackgroundColor3=c1}):Play() end)
	return btn
end

local loopBtn = makeBtn("🔁 LOOP: OFF", 12,       84, BW, 34, Color3.fromRGB(150,18,18), Color3.fromRGB(90,8,8))
local viewBtn = makeBtn("👁 VIEW: OFF",  12+BW+8, 84, BW, 34, Color3.fromRGB(20,60,100),  Color3.fromRGB(10,35,65))
